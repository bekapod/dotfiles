[user]
	name = Becky

[init]
	defaultBranch = main

[merge]
	conflictStyle = zdiff3

[pull]
	rebase = true

[push]
	autosetupremote = true

[rerere]
	enabled = true

[safe]
	directory = *
[core]
	editor = nvim
	excludesfile = /Users/becky/.gitignore
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
